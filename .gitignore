# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
dist/
build/

# Eval-runner outputs (the held-out JSONL itself is tracked; the
# results_<timestamp>.json files are per-run artifacts that
# shouldn't clutter git history).
eval/results_*.json
# Same for the Ragas runner (Phase 6.7, card t_bb4e96e0). The
# held-out match + comprehension JSONLs are tracked; the
# per-run ragas_results_<timestamp>.jsonl files are scratch.
eval/ragas_results_*.jsonl
eval/ragas_results.jsonl
# Phase 7.5 retrieval-quality A/B runner. The held-out cloze
# JSONL is tracked; the per-run directory is scratch.
eval/retrieval_compare/

# Worktrees (ephemeral)
wt/

# Node
node_modules/
.pnpm-store/

# OS / editor
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Local env files / secrets
.env
.env.local
*.local

# Logs
*.log
logs/

# Build output
frontend/dist/

# Backend runtime data
# The .db file is generated from the (private) loader pipeline. Keep it
# in the repo so `docker compose up` Just Works on a fresh clone, but
# allow local replacement.
backend/data/*.db.local

# Generated Anki decks are produced at runtime by the API. Keep them
# out of git history.
backend/generated_decks/

# Phase 4.2 — DSPy optimizer output (card t_bdd9ffbe). Re-written
# every time ``uv run python -m scripts.optimize_cloze`` runs; not
# a source-of-truth artifact, so it stays out of git history.
backend/app/cloze_optimized.json
