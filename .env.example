# Lexora environment configuration.
#
# Copy to .env at the repo root, OR keep in ~/.lexora/.env (recommended
# for secrets like Langfuse keys). docker compose reads both: project
# .env is picked up automatically; ~/.lexora/.env can be sourced into
# the shell before `docker compose up` or symlinked into the project root.
#
# The Postgres URL below assumes the bundled docker-compose service is
# running locally. To fall back to the shipped SQLite corpus instead:
#   DATABASE_URL=sqlite:///./data/vocabeo_words.db

# --- Database ---
# Default: bundled Postgres + pgvector (host port 25432, internal 5432).
DATABASE_URL=postgresql+psycopg://lexora:lexora@postgres:5432/lexora
# SQLite fallback (dev only -- requires backend/data/vocabeo_words.db):
# DATABASE_URL=sqlite:///./data/vocabeo_words.db

# --- Langfuse (observability) ---
# Project-scoped credentials for the dedicated "lexora" project on the
# shared Langfuse instance (http://localhost:13000). Generate these in
# the Langfuse UI -> project settings -> API Keys. NEVER commit them.

LANGFUSE_PUBLIC_KEY=pk-lf-placeholder
LANGFUSE_SECRET_KEY=sk-lf-placeholder

# Where the backend reaches Langfuse. Default uses host.docker.internal
# so the backend container can dial the host's shared instance.
LANGFUSE_HOST=http://host.docker.internal:13000

# --- OpenRouter (LLM + embeddings) ---
# Phase 1 (embeddings + retrieval): only the OpenRouter API key +
# EMBEDDING_MODEL are read. Phase 4 (chat) adds OPENROUTER_BASE_URL +
# OPENROUTER_CHAT_MODEL.
#
# The OpenRouter API key is sourced from the host systemd env
# (~/.config/environment.d/hermes-openrouter.conf) which docker
# compose picks up automatically. The var name deliberately avoids
# TOKEN/SECRET semantics so the harness does not redact the value.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Embedding model. Default qwen/qwen3-embedding-8b (1024-dim, matches
# the spec baai/bge-m3 target on dimensionality; bge-m3 is not
# available under the account's current privacy settings, see
# NOTES.md Phase 1 outcome section).
EMBEDDING_MODEL=qwen/qwen3-embedding-8b
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_ATTEMPTS=3

# Chat model (Phase 4.1). Default qwen/qwen3-235b-a22b-2507; the
# Phase 4 plan probed the public OpenRouter /v1/models endpoint at
# build time (2026-07-03) and confirmed availability. The base URL
# above is reused — same OpenRouter host serves both endpoints.
# Same data-policy caveat as the embedding model: if this id is
# blocked by the account's privacy filter, override here and the
# backend will pick it up on the next container restart.
OPENROUTER_CHAT_MODEL=qwen/qwen3-235b-a22b-2507

# --- Auth (Phase 2.2 wires bcrypt + JWT) ---
# JWT signing secret. Generate a fresh value with:
#     openssl rand -hex 32
# Then paste the output below (32 random bytes = 64 hex chars).
# Phase 2.2 reads JWT_SECRET at app import time and refuses to
# boot if it's still the placeholder ("change-me-in-production")
# or shorter than 32 characters. Keep this file committed with
# the variable name; the value lives in ~/.lexora/.env per the
# Phase 0 convention.
JWT_SECRET=change-me-in-production

